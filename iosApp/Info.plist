<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Partial Info.plist merged with the keys generated by GENERATE_INFOPLIST_FILE.
	  ATS exception so the app can reach the local dev server over plain HTTP:
	  NSAllowsLocalNetworking permits localhost (simulator) and private LAN IPs
	  (device, e.g. http://192.168.x.x:8000) while keeping ATS on for the public
	  internet. The deployed Cloudflare HTTPS URL needs no exception.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
